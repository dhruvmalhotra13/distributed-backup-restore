# ---- Distributed Backup & Restore Platform : environment ----
# Copy this file to ".env" and adjust paths for your machine.

# Host folder that will be backed up. It is mounted into the containers at
# /data/source, so when creating a backup job use a source path like
# "/data/source" (or a subfolder, e.g. "/data/source/photos").
SOURCE_DIR=./sample-data

# Host folder where the Backup Vault (chunks + metadata) is stored.
# Mounted into the containers at /data/BackupVault.
VAULT_DIR=./data/BackupVault

# PostgreSQL credentials
POSTGRES_USER=backup
POSTGRES_PASSWORD=backup
POSTGRES_DB=backup

# Host port to expose the API on (Swagger at http://localhost:8080/swagger)
API_PORT=8080
