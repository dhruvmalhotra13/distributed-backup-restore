# ---- Distributed Backup & Restore Platform : environment ----
# Copy this file to ".env" and adjust paths for your machine.

# Your user folder. It is mounted once into the containers at /host, so you can
# back up or restore ANY folder under it just by typing its real path in the UI
# (e.g. C:\Users\you\Desktop\MyProject). No need to edit this per folder.
# Windows example: C:/Users/you    macOS/Linux example: /Users/you or /home/you
HOST_HOME=C:/Users/you

# Host folder where the Backup Vault (chunks + metadata) is stored.
# Mounted into the containers at /data/BackupVault.
VAULT_DIR=./data/BackupVault

# PostgreSQL credentials
POSTGRES_USER=backup
POSTGRES_PASSWORD=backup
POSTGRES_DB=backup

# Host port to expose the API on (Swagger at http://localhost:8080/swagger)
API_PORT=8080

# Host port to expose the web dashboard on (http://localhost:3000)
FRONTEND_PORT=3000
